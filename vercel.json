{
  "version": 2,
  "builds": [
    { "src": "api/upload.js",  "use": "@vercel/node" },
    { "src": "api/proxy.js",   "use": "@vercel/node" },
    { "src": "api/analyze.js", "use": "@vercel/node" },
    { "src": "public/**",      "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/upload",  "dest": "/api/upload.js" },
    { "src": "/api/proxy",   "dest": "/api/proxy.js" },
    { "src": "/api/analyze", "dest": "/api/analyze.js" },
    { "src": "/(.*)",        "dest": "/public/$1" }
  ]
}
